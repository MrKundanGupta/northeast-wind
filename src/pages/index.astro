---
export const prerender = true;
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PlaceCard from "../components/PlaceCard.astro";

const allPlaces = await getCollection("places");
const allHubCities = await getCollection("hubCities");
const states = [
  ...new Set([
    ...allPlaces.map((p) => p.data.location.state),
    ...allHubCities.map((p) => p.data.location.state),
  ]),
].sort();

const featured = allPlaces
  .filter((p) => p.data.ratings.google_rating !== null)
  .sort((a, b) => (b.data.ratings.google_rating ?? 0) - (a.data.ratings.google_rating ?? 0))
  .slice(0, 6);

// State card images — local photos from our Places API collection
const STATE_IMAGES: Record<string, string> = {
  "Arunachal Pradesh": "/images/arunachal-pradesh/tawang-monastery/1.jpg",
  "Assam":             "/images/assam/kaziranga-national-park/1.jpg",
  "Manipur":           "/images/manipur/loktak-lake/1.png",
  "Meghalaya":         "/images/meghalaya/nohkalikai-falls/1.jpg",
  "Mizoram":           "/images/mizoram/vantawng-falls/1.jpg",
  "Nagaland":          "/images/nagaland/dzukou-valley/1.jpg",
  "Sikkim":            "/images/sikkim/tsomgo-lake/1.jpg",
  "Tripura":           "/images/tripura/neermahal/1.jpg",
};
const FALLBACK_IMG = "/images/nagaland/dzukou-valley/1.jpg";
---

<BaseLayout title="Axomor — Discover Northeast India">

  {/* ═══ HERO ════════════════════════════════════════════════════════ */}
  <section style="position: relative; min-height: 96vh; display: flex; align-items: center; overflow: hidden;">

    {/* Background photo layer */}
    <div style={`
      position: absolute; inset: 0;
      background-image: url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&w=2560&q=80');
      background-size: cover;
      background-position: center 30%;
    `}></div>

    {/* Layered gradient over photo */}
    <div style="position: absolute; inset: 0; background: linear-gradient(135deg, rgba(30,61,16,0.93) 0%, rgba(30,61,16,0.72) 45%, rgba(58,122,36,0.60) 70%, rgba(30,61,16,0.85) 100%);"></div>

    {/* Tribal pattern overlay */}
    <div class="tribal-pattern-dense" style="position: absolute; inset: 0; opacity: 0.35; pointer-events: none;"></div>

    {/* Ambient gold orb */}
    <div style="position: absolute; top: -10%; right: -5%; width: 55vw; height: 55vw; border-radius: 50%; background: radial-gradient(circle, rgba(196,137,42,0.14) 0%, transparent 65%); pointer-events: none;"></div>
    <div style="position: absolute; bottom: -8%; left: -4%; width: 40vw; height: 40vw; border-radius: 50%; background: radial-gradient(circle, rgba(30,122,71,0.12) 0%, transparent 65%); pointer-events: none;"></div>

    {/* Content */}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-28 sm:py-32 relative" style="z-index: 1; width: 100%;">
      <div class="max-w-3xl">

        {/* Eyebrow with decorative lines */}
        <div class="animate-fade-up animate-delay-1 flex items-center gap-3 mb-7">
          <div style="width: 2.5rem; height: 1px; background: linear-gradient(90deg, transparent, #D4A843);"></div>
          <p class="label-caption" style="color: #D4A843; letter-spacing: 0.16em;">Northeast India · Eight Sister States</p>
          <div style="width: 2.5rem; height: 1px; background: linear-gradient(90deg, #D4A843, transparent);"></div>
        </div>

        {/* Headline */}
        <h1 class="animate-fade-up animate-delay-2"
            style="font-family: 'Cormorant Garamond', serif; font-size: clamp(3rem, 8.5vw, 6.25rem); font-weight: 300; color: #F9F4EC; line-height: 1.0; letter-spacing: -0.025em; margin-bottom: 1.75rem;">
          Discover the<br />
          <em style="font-style: italic; font-weight: 400; color: #D4A843;">Last Frontier</em><br />
          of India
        </h1>

        {/* Gold divider with compass star */}
        <div class="animate-fade-up animate-delay-2" style="display: flex; align-items: center; gap: 0.875rem; margin-bottom: 2rem;">
          <div style="width: 3.5rem; height: 1.5px; background: linear-gradient(90deg, #C4892A, #D4A843);"></div>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="rgba(212,168,67,0.85)">
            <path d="M12 2L14 9L21 12L14 15L12 22L10 15L3 12L10 9Z"/>
          </svg>
          <div style="width: 3.5rem; height: 1.5px; background: linear-gradient(90deg, #D4A843, #C4892A);"></div>
        </div>

        {/* Description */}
        <p class="animate-fade-up animate-delay-3"
           style="font-size: clamp(1rem, 2vw, 1.175rem); color: rgba(249,244,236,0.68); line-height: 1.85; max-width: 530px; margin-bottom: 2.75rem; font-family: 'Outfit', sans-serif; font-weight: 300;">
          {allPlaces.length}+ handpicked destinations — from mist-shrouded Himalayan peaks and ancient monasteries to living root bridges, sacred lakes, and rare wildlife sanctuaries.
        </p>

        {/* CTAs */}
        <div class="animate-fade-up animate-delay-4 flex flex-wrap gap-4 mb-20">
          <a href="/plan" class="btn-forest inline-flex items-center gap-2.5"
             style="font-family: 'Outfit', sans-serif; font-size: 0.9375rem; font-weight: 600;">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0"/>
              <path d="M12 8v4l3 3"/>
            </svg>
            Plan My Trip
          </a>
          <a href="#destinations"
             class="inline-flex items-center gap-2.5 rounded-full px-7 py-3 transition"
             style="border: 1.5px solid rgba(249,244,236,0.28); color: rgba(249,244,236,0.88); font-family: 'Outfit', sans-serif; font-size: 0.9375rem; font-weight: 500; background: rgba(249,244,236,0.06); backdrop-filter: blur(8px);">
            Browse Places
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        </div>

        {/* Stats row */}
        <div class="animate-fade-up animate-delay-5 flex flex-wrap gap-10 pt-8"
             style="border-top: 1px solid rgba(196,137,42,0.22);">
          {[
            { value: `${allPlaces.length}+`, label: "Destinations" },
            { value: `${states.length}`,     label: "States" },
            { value: "8",                    label: "Ecosystems" },
            { value: "400+",                 label: "Hidden Gems" },
          ].map(stat => (
            <div>
              <p style="font-family: 'Cormorant Garamond', serif; font-size: 2.5rem; font-weight: 500; color: #F9F4EC; line-height: 1;">{stat.value}</p>
              <p style="font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.10em; text-transform: uppercase; color: rgba(196,137,42,0.78); margin-top: 0.2rem; font-family: 'Outfit', sans-serif;">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    {/* Scroll indicator */}
    <div class="animate-float" style="position: absolute; bottom: 2.5rem; left: 50%; z-index: 2; display: flex; flex-direction: column; align-items: center; gap: 0.5rem;">
      <p style="font-size: 0.625rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(249,244,236,0.40); font-family: 'Outfit', sans-serif;">Scroll</p>
      <div style="width: 1px; height: 2.5rem; background: linear-gradient(to bottom, rgba(212,168,67,0.70), transparent);"></div>
    </div>
  </section>

  {/* ═══ EIGHT STATES ════════════════════════════════════════════════ */}
  <section style="background: #F9F4EC; padding: 6rem 0 5rem;">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

      {/* Section header */}
      <div class="reveal" style="margin-bottom: 3rem; text-align: center;">
        <p class="label-caption" style="margin-bottom: 0.75rem; display: block;">The Eight Sister States</p>
        <h2 style="font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 400; color: #1C1208; line-height: 1.15; margin-bottom: 1rem;">
          Eight Extraordinary <em style="font-style: italic; color: #145C35;">Worlds</em>
        </h2>
        <p style="font-size: 0.9375rem; color: #7A6555; font-family: 'Outfit', sans-serif; font-weight: 300; max-width: 480px; margin: 0 auto;">
          Each state is a universe unto itself — pick one to begin.
        </p>
      </div>

      {/* State image grid */}
      <div class="grid gap-4 grid-cols-2 sm:grid-cols-3 lg:grid-cols-4">
        {states.map((state, i) => {
          const count = allPlaces.filter((p) => p.data.location.state === state).length;
          const img = STATE_IMAGES[state] ?? FALLBACK_IMG;
          return (
            <a
              href={`/states/${state.toLowerCase().replace(/\s+/g, "-")}`}
              class={`state-img-card reveal`}
              style={`aspect-ratio: 3/4; animation-delay: ${i * 0.06}s;`}
            >
              <img src={img} alt={`${state} landscape`} loading="lazy" decoding="async" />
              <div class="card-overlay"></div>
              <div class="card-content">
                <p style="font-size: 0.625rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(212,168,67,0.85); font-family: 'Outfit', sans-serif; margin-bottom: 0.375rem;">
                  {count} destinations
                </p>
                <h3 style="font-family: 'Cormorant Garamond', serif; font-size: clamp(1.1rem, 2.5vw, 1.4rem); font-weight: 500; color: #F9F4EC; line-height: 1.15; margin-bottom: 0.625rem;">
                  {state}
                </h3>
                <div class="explore-arrow">
                  <span>Explore</span>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                  </svg>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  {/* ═══ FEATURED DESTINATIONS ══════════════════════════════════════ */}
  <section id="destinations" style="background: #F2EAD6; padding: 6rem 0;">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

      {/* Section header */}
      <div class="reveal flex items-end justify-between mb-10">
        <div>
          <p class="label-caption" style="margin-bottom: 0.625rem; display: block;">Travellers' Favourites</p>
          <h2 style="font-family: 'Cormorant Garamond', serif; font-size: clamp(1.875rem, 4vw, 2.875rem); font-weight: 400; color: #1C1208; line-height: 1.15;">
            Top Rated <em style="font-style: italic; color: #145C35;">Destinations</em>
          </h2>
          <div style="width: 3.5rem; height: 1.5px; background: linear-gradient(90deg, #C4892A, transparent); margin-top: 0.875rem;"></div>
        </div>
        <a href="/states"
           class="hidden sm:inline-flex items-center gap-1.5 text-sm font-semibold transition"
           style="color: #145C35; font-family: 'Outfit', sans-serif; text-decoration: none; padding: 0.5rem 1rem; border: 1px solid rgba(58,122,36,0.25); border-radius: 9999px;">
          View all
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {featured.map((place, i) => (
          <div class="reveal" style={`animation-delay: ${i * 0.08}s;`}>
            <PlaceCard
              id={place.id}
              name={place.data.name}
              category={place.data.category}
              subCategory={place.data.sub_category}
              state={place.data.location.state}
              googleRating={place.data.ratings.google_rating}
              reviewsCount={place.data.ratings.google_reviews_count}
              tags={place.data.tags}
              image={place.data.images[0]}
              logistics={place.data.logistics}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ═══ PLAN CTA BANNER ════════════════════════════════════════════ */}
  <section class="plan-cta-section tribal-pattern-dense">
    {/* Top accent line */}
    <div style="height: 2px; background: linear-gradient(90deg, #6B4A12, #C4892A, #D4A843, #C4892A, #6B4A12);"></div>

    {/* Gold orb */}
    <div style="position: absolute; top: -60px; right: -60px; width: 320px; height: 320px; border-radius: 50%; background: radial-gradient(circle, rgba(196,137,42,0.14) 0%, transparent 65%); pointer-events: none;"></div>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20 relative text-center">
      <p class="label-caption reveal" style="color: #D4A843; margin-bottom: 1rem; display: block;">Hub-based planning</p>
      <h2 class="reveal" style="font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 300; color: #F9F4EC; line-height: 1.15; margin-bottom: 1.25rem; max-width: 700px; margin-left: auto; margin-right: auto;">
        Know your <em style="font-style: italic; color: #D4A843;">flight or train</em> arrival?<br/>Plan destinations by drive time.
      </h2>
      <p class="reveal" style="font-size: 1rem; color: rgba(249,244,236,0.60); font-family: 'Outfit', sans-serif; font-weight: 300; max-width: 460px; margin: 0 auto 2.5rem; line-height: 1.75;">
        Select your hub airport or station. We'll show you every destination reachable within your available time.
      </p>
      <a href="/plan" class="reveal btn-forest inline-flex items-center gap-2.5"
         style="font-family: 'Outfit', sans-serif; font-size: 0.9375rem;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/>
          <line x1="9" y1="3" x2="9" y2="18"/>
          <line x1="15" y1="6" x2="15" y2="21"/>
        </svg>
        Start Planning
      </a>
    </div>
    <div style="height: 2px; background: linear-gradient(90deg, #6B4A12, #C4892A, #D4A843, #C4892A, #6B4A12);"></div>
  </section>

  {/* ═══ ALL DESTINATIONS ═══════════════════════════════════════════ */}
  <section style="background: #F9F4EC; padding: 6rem 0;">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

      {/* Section header */}
      <div class="reveal" style="margin-bottom: 3rem;">
        <p class="label-caption" style="margin-bottom: 0.625rem; display: block;">The complete collection</p>
        <h2 style="font-family: 'Cormorant Garamond', serif; font-size: clamp(1.875rem, 4vw, 2.875rem); font-weight: 400; color: #1C1208; line-height: 1.15;">
          All {allPlaces.length} <em style="font-style: italic; color: #145C35;">Destinations</em>
        </h2>
        <div style="width: 3.5rem; height: 1.5px; background: linear-gradient(90deg, #C4892A, transparent); margin-top: 0.875rem;"></div>
        <p style="margin-top: 0.75rem; font-size: 0.9375rem; color: #7A6555; font-family: 'Outfit', sans-serif; font-weight: 300;">
          Every place worth visiting in Northeast India, curated by local knowledge.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {allPlaces.map((place) => (
          <PlaceCard
            id={place.id}
            name={place.data.name}
            category={place.data.category}
            subCategory={place.data.sub_category}
            state={place.data.location.state}
            googleRating={place.data.ratings.google_rating}
            reviewsCount={place.data.ratings.google_reviews_count}
            tags={place.data.tags}
            image={place.data.images[0]}
            logistics={place.data.logistics}
          />
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .plan-cta-section { position: relative; }
</style>
