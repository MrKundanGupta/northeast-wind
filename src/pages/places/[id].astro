---
export const prerender = true;
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const places = await getCollection("places");
  const hubCities = await getCollection("hubCities");
  const allEntries = [...places, ...hubCities];
  return allEntries.map((place) => ({
    params: { id: place.id },
    props: { place },
  }));
}

const { place } = Astro.props;
const { Content } = await render(place);
const d = place.data;

const heroImage = d.hub_images?.[0] || d.images?.[0] || null;
const galleryImages = d.hub_images?.slice(1, 3) ?? [];
const stateSlug = d.location.state.toLowerCase().replace(/\s+/g, "-");
const placeUrl = `https://axomor.com/places/${place.id}/`;

const allImages = [...(d.hub_images ?? []), ...(d.images ?? [])];

const isSpiritual = d.category === "Spiritual";
const jsonLd = {
  "@context": "https://schema.org",
  "@type": isSpiritual ? ["PlaceOfWorship", "LocalBusiness"] : ["TouristAttraction", "LocalBusiness"],
  name: d.name,
  description: d.seo.meta_description,
  url: placeUrl,
  ...(allImages.length > 0 && {
    image: allImages.map(img => ({ "@type": "ImageObject", url: img })),
  }),
  geo: {
    "@type": "GeoCoordinates",
    latitude: d.location.lat,
    longitude: d.location.lng,
  },
  address: {
    "@type": "PostalAddress",
    addressLocality: d.location.address,
    addressRegion: d.location.state,
    addressCountry: "IN",
  },
  publicAccess: true,
  ...(d.ratings?.google_rating && {
    aggregateRating: {
      "@type": "AggregateRating",
      ratingValue: Number(d.ratings.google_rating),
      reviewCount: Number(d.ratings.google_reviews_count) || 5,
      bestRating: 5,
      worstRating: 1,
    },
  }),
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://axomor.com/" },
    { "@type": "ListItem", position: 2, name: d.location.state, item: `https://axomor.com/states/${stateSlug}/` },
    { "@type": "ListItem", position: 3, name: d.name, item: placeUrl },
  ],
};
---

<BaseLayout title={d.seo.meta_title} description={d.seo.meta_description} image={heroImage ?? undefined}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

  {/* Hero Image */}
  {heroImage ? (
    <div class="relative h-[55vh] min-h-[340px] w-full overflow-hidden bg-gray-900">
      <picture>
        <source srcset={heroImage!.replace(/\.(jpe?g|png)$/i, '.webp')} type="image/webp" />
        <img
          src={heroImage}
          alt={d.name}
          class="h-full w-full object-cover opacity-85"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </picture>
      {/* Bottom-up: darken text area heavily */}
      <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.75) 30%, rgba(0,0,0,0.30) 60%, transparent 100%);"></div>
      {/* Top-down: subtle scrim so category badges stay legible */}
      <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(0,0,0,0.45) 0%, transparent 35%);"></div>

      {/* Overlay content */}
      <div class="absolute bottom-0 left-0 right-0 px-6 pb-8 sm:px-10 lg:px-16">
        <div class="mx-auto max-w-5xl">
          {/* Category badges */}
          <div class="mb-3 flex flex-wrap items-center gap-2">
            <span class="rounded-full bg-emerald-500/90 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white backdrop-blur-sm">
              {d.category}
            </span>
            <span class="rounded-full bg-white/20 px-3 py-1 text-xs font-medium text-white backdrop-blur-sm">
              {d.sub_category}
            </span>
          </div>

          <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl" style="text-shadow: 0 2px 16px rgba(0,0,0,0.60), 0 1px 4px rgba(0,0,0,0.40);">
            {d.name}
          </h1>

          <p class="mt-2 text-sm text-white/80 sm:text-base">
            <svg class="mr-1 inline h-4 w-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            {d.location.address}, {d.location.state}
          </p>

          {/* Rating */}
          {d.ratings.google_rating && (
            <div class="mt-3 flex items-center gap-3">
              <div class="flex items-center gap-1 rounded-full bg-amber-500/90 px-3 py-1 backdrop-blur-sm">
                <svg class="h-4 w-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
                <span class="text-sm font-bold text-white">{d.ratings.google_rating}</span>
              </div>
              {d.ratings.google_reviews_count && (
                <span class="text-sm text-white/70">{d.ratings.google_reviews_count} reviews</span>
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  ) : (
    <div class="bg-emerald-900 px-6 py-16 sm:px-10 lg:px-16">
      <div class="mx-auto max-w-5xl">
        <div class="mb-3 flex flex-wrap items-center gap-2">
          <span class="rounded-full bg-emerald-500 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white">{d.category}</span>
          <span class="rounded-full bg-white/20 px-3 py-1 text-xs font-medium text-white">{d.sub_category}</span>
        </div>
        <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">{d.name}</h1>
        <p class="mt-2 text-white/70">{d.location.address}, {d.location.state}</p>
      </div>
    </div>
  )}

  <div class="mx-auto max-w-5xl px-4 py-8 sm:px-6 lg:px-8">

    {/* Breadcrumb + Plan CTA */}
    <div class="mb-8 flex flex-wrap items-center justify-between gap-3">
      <nav class="text-sm text-gray-500">
        <a href="/" class="hover:text-emerald-700">Home</a>
        <span class="mx-2">/</span>
        <a href={`/states/${stateSlug}/`} class="hover:text-emerald-700">{d.location.state}</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">{d.name}</span>
      </nav>
      <button
        data-plan-trip
        class="inline-flex items-center gap-2 rounded-xl bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700 transition shadow-sm"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c-.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
        </svg>
        Plan My Trip
      </button>
    </div>

    <div class="lg:grid lg:grid-cols-3 lg:gap-10">

      {/* Main Column */}
      <div class="lg:col-span-2">

        {/* Tags */}
        {d.tags.length > 0 && (
          <div class="mb-6 flex flex-wrap gap-2">
            {d.tags.map((tag) => (
              <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-medium text-emerald-700 ring-1 ring-emerald-200">
                {tag}
              </span>
            ))}
          </div>
        )}

        {/* Seasonality — best months */}
        {d.seasonality?.best_months?.length > 0 && (
          <div class="mb-8 rounded-xl border border-emerald-100 bg-emerald-50/60 p-5">
            <h2 class="mb-3 flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-emerald-800">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              Best Time to Visit
            </h2>
            <div class="flex flex-wrap gap-2">
              {d.seasonality.best_months.map((month) => (
                <span class="rounded-md bg-white px-3 py-1 text-sm font-medium text-gray-700 shadow-sm ring-1 ring-gray-200">
                  {month}
                </span>
              ))}
            </div>
            {d.seasonality.peak_events?.length > 0 && (
              <p class="mt-3 text-sm text-emerald-700">
                <span class="font-medium">Events: </span>
                {d.seasonality.peak_events.join(" · ")}
              </p>
            )}
          </div>
        )}

        {/* MDX content (About, How to Reach, etc.) */}
        <div class="prose prose-emerald max-w-none prose-headings:font-bold prose-h2:text-xl prose-h2:mt-8 prose-h2:mb-3 prose-p:text-gray-700 prose-a:text-emerald-700">
          <Content />
        </div>

        {/* Photo Gallery */}
        {galleryImages.length > 0 && (
          <section class="mt-10">
            <h2 class="mb-4 text-xl font-bold text-gray-900">Photo Gallery</h2>
            <div class={`grid gap-3 ${galleryImages.length === 1 ? "grid-cols-1" : "grid-cols-2"}`}>
              {galleryImages.map((img, i) => (
                <div class="overflow-hidden rounded-xl">
                  <picture>
                    <source srcset={img.replace(/\.(jpe?g|png)$/i, '.webp')} type="image/webp" />
                    <img
                      src={img}
                      alt={`${d.name} photo ${i + 2}`}
                      class="h-56 w-full object-cover transition duration-300 hover:scale-105"
                      loading="lazy"
                      decoding="async"
                    />
                  </picture>
                </div>
              ))}
            </div>
          </section>
        )}

        {/* Location */}
        <div class="mt-10 rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
          <h2 class="mb-4 flex items-center gap-2 text-lg font-bold text-gray-900">
            <svg class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Location
          </h2>
          <p class="text-sm text-gray-600">{d.location.address}, {d.location.state}</p>
          <p class="mt-1 text-xs text-gray-400">
            {d.location.lat}°N, {d.location.lng}°E
          </p>
          <a
            href={d.map_location?.Maps_url || `https://www.google.com/maps?q=${d.location.lat},${d.location.lng}`}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            Open in Google Maps
          </a>
        </div>
      </div>

      {/* Sidebar */}
      <aside class="mt-10 space-y-4 lg:mt-0 lg:sticky lg:top-6 lg:self-start">

        {/* Visiting Hours */}
        {d.visiting_hours && (
          <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
            <h3 class="mb-3 flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-gray-500">
              <svg class="h-4 w-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Visiting Hours
            </h3>
            <p class="text-base font-semibold text-gray-900">
              {d.visiting_hours.open_time} — {d.visiting_hours.close_time}
            </p>
            {d.visiting_hours.closed_days?.filter(d => d !== "None").length > 0 && (
              <p class="mt-1 text-sm text-red-600">
                Closed: {d.visiting_hours.closed_days.filter(d => d !== "None").join(", ")}
              </p>
            )}
            {d.visiting_hours.notes && (
              <p class="mt-2 text-xs text-gray-500">{d.visiting_hours.notes}</p>
            )}
          </div>
        )}

        {/* Entry Fees */}
        {d.entry_fees && (d.entry_fees.indian_inr || d.entry_fees.foreigner_inr) && (
          <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
            <h3 class="mb-3 flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-gray-500">
              <svg class="h-4 w-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 9a2 2 0 10-4 0v5a2 2 0 01-2 2h6m-6-4h4m8 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Entry Fees
            </h3>
            {d.entry_fees.indian_inr && (
              <div class="flex items-center justify-between py-1.5 text-sm">
                <span class="text-gray-600">Indian</span>
                <span class="font-semibold text-gray-900">₹{d.entry_fees.indian_inr}</span>
              </div>
            )}
            {d.entry_fees.foreigner_inr && (
              <div class="flex items-center justify-between border-t border-gray-100 py-1.5 text-sm">
                <span class="text-gray-600">Foreigner</span>
                <span class="font-semibold text-gray-900">₹{d.entry_fees.foreigner_inr}</span>
              </div>
            )}
            {d.entry_fees.special_entry_notes && (
              <p class="mt-2 text-xs text-gray-500">{d.entry_fees.special_entry_notes}</p>
            )}
          </div>
        )}

        {/* Permits */}
        <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
          <h3 class="mb-3 flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-gray-500">
            <svg class="h-4 w-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            Permits
          </h3>
          <div class="space-y-2">
            <div class="flex items-center justify-between text-sm">
              <span class="text-gray-600">ILP</span>
              <span class={`rounded-full px-2.5 py-0.5 text-xs font-semibold ${d.permit_requirements.ilp_required ? "bg-red-100 text-red-700" : "bg-green-100 text-green-700"}`}>
                {d.permit_requirements.ilp_required ? "Required" : "Not needed"}
              </span>
            </div>
            {d.permit_requirements.pap_required !== undefined && (
              <div class="flex items-center justify-between text-sm">
                <span class="text-gray-600">PAP</span>
                <span class={`rounded-full px-2.5 py-0.5 text-xs font-semibold ${d.permit_requirements.pap_required ? "bg-red-100 text-red-700" : "bg-green-100 text-green-700"}`}>
                  {d.permit_requirements.pap_required ? "Required" : "Not needed"}
                </span>
              </div>
            )}
          </div>
          {d.permit_requirements.permit_details && (
            <p class="mt-3 text-xs text-gray-500 leading-relaxed">{d.permit_requirements.permit_details}</p>
          )}
        </div>

        {/* How to Reach (Logistics) */}
        {d.logistics?.length > 0 && (
          <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
            <h3 class="mb-3 flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-gray-500">
              <svg class="h-4 w-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0" />
              </svg>
              How to Reach
            </h3>
            <div class="space-y-3">
              {d.logistics.map((leg) => {
                const icons = {
                  airport: "✈",
                  train: "🚂",
                  bus: "🚌",
                  car: "🚗",
                };
                return (
                  <div class="flex items-start gap-2 text-sm">
                    <span class="mt-0.5 text-base leading-none">{icons[leg.hub_type] || "📍"}</span>
                    <div>
                      <p class="font-medium text-gray-900">{leg.hub_name}</p>
                      <p class="text-gray-500">{leg.distance_km} km · ~{Math.round(leg.drive_time_mins / 60) > 0 ? `${Math.round(leg.drive_time_mins / 60)}h ` : ""}{leg.drive_time_mins % 60 > 0 ? `${leg.drive_time_mins % 60}m` : ""}</p>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        )}
      </aside>
    </div>
  </div>
</BaseLayout>
