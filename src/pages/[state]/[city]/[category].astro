---
export const prerender = true;
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import {
  cities,
  categories,
  interpolate,
  getMonthYear,
  getNearbyCities,
  deriveBestFor,
  deriveBestForGoogle,
  getMdxPlacesForCity,
  getGooglePlacesForCity,
  buildTouristAttractionSchema,
  buildLocalBusinessSchema,
  buildNearMeFaqs,
  buildFaqSchema,
  type PseoCity,
  type PseoCategory,
  type GooglePlace,
} from "../../../lib/near-me";
import pseoPlacesData from "../../../data/pseo-places.json";

/* ------------------------------------------------------------------ */
/*  getStaticPaths — 18 cities × 6 categories = 108 pages             */
/* ------------------------------------------------------------------ */

export async function getStaticPaths() {
  const allPlaces = await getCollection("places");
  const paths: any[] = [];

  for (const city of cities) {
    for (const cat of categories) {
      let mdxPlaces: any[] = [];
      let googlePlaces: GooglePlace[] = [];

      if (cat.source === "mdx") {
        mdxPlaces = getMdxPlacesForCity(allPlaces, city, cat);
        mdxPlaces.sort(
          (a, b) =>
            (b.data.ratings.google_rating ?? 0) -
            (a.data.ratings.google_rating ?? 0),
        );
      } else {
        googlePlaces = getGooglePlacesForCity(
          pseoPlacesData,
          city.slug,
          cat.slug,
        );
      }

      paths.push({
        params: {
          state: city.stateSlug,
          city: city.slug,
          category: cat.slug,
        },
        props: { city, cat, mdxPlaces, googlePlaces },
      });
    }
  }

  return paths;
}

/* ------------------------------------------------------------------ */
/*  Page props                                                         */
/* ------------------------------------------------------------------ */

const { city, cat, mdxPlaces, googlePlaces } = Astro.props as {
  city: PseoCity;
  cat: PseoCategory;
  mdxPlaces: any[];
  googlePlaces: GooglePlace[];
};

const isMdx = cat.source === "mdx";
const totalCount = isMdx ? mdxPlaces.length : googlePlaces.length;
const year = new Date().getFullYear();
const monthYear = getMonthYear();

const tplVars = {
  city: city.name,
  state: city.state,
  year,
  count: totalCount,
  label: cat.label,
  monthYear,
};

const pageTitle = interpolate(cat.metaTitleTemplate, tplVars);
const pageDescription = interpolate(cat.metaDescriptionTemplate, tplVars);
const h1Text = interpolate(cat.h1Template, tplVars);
const introText = interpolate(cat.introTemplate, tplVars);

/* ── Hero background image ──────────────────────────────────────── */
const heroImage = isMdx
  ? mdxPlaces[0]?.data.images[0] ?? ""
  : googlePlaces[0]?.photos[0] ?? "";

/* ── Top place for FAQs ─────────────────────────────────────────── */
const topName = isMdx
  ? mdxPlaces[0]?.data.name ?? null
  : googlePlaces[0]?.name ?? null;
const topRating = isMdx
  ? mdxPlaces[0]?.data.ratings.google_rating ?? null
  : googlePlaces[0]?.rating ?? null;

/* ── Schema.org JSON-LD ─────────────────────────────────────────── */
const itemListSchema =
  totalCount > 0
    ? cat.schemaType === "TouristAttraction"
      ? buildTouristAttractionSchema(mdxPlaces, city.name, city.state)
      : buildLocalBusinessSchema(googlePlaces, city.name, city.state, cat.label)
    : null;

const faqItems = buildNearMeFaqs(
  city.name,
  city.state,
  cat.label,
  totalCount,
  topName,
  topRating,
);
const faqSchema = buildFaqSchema(faqItems);

/* ── Internal linking data ──────────────────────────────────────── */
const otherCategories = categories.filter((c) => c.slug !== cat.slug);
const nearbyCities = getNearbyCities(city, 3);
---

<BaseLayout title={pageTitle} description={pageDescription}>

  {/* ── JSON-LD in head ─────────────────────────────────────────── */}
  {itemListSchema && (
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  )}
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  {/* ═══ Hero ══════════════════════════════════════════════════════ */}
  <section class="relative overflow-hidden bg-gray-900 py-20 sm:py-28">
    {heroImage && (
      <img
        src={heroImage}
        alt={`${cat.label} in ${city.name}`}
        class="absolute inset-0 h-full w-full object-cover opacity-30"
      />
    )}
    <div class="absolute inset-0 bg-gradient-to-r from-gray-900/95 to-gray-900/60" />

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      {/* Breadcrumb (4-level) */}
      <nav class="mb-8 flex items-center gap-2 text-sm text-gray-400">
        <a href="/" class="hover:text-white">Home</a>
        <span>/</span>
        <a href={`/states/${city.stateSlug}`} class="hover:text-white">{city.state}</a>
        <span>/</span>
        <a href={`/${city.stateSlug}/${city.slug}`} class="hover:text-white">{city.name}</a>
        <span>/</span>
        <span class="text-white">{cat.label}</span>
      </nav>

      {/* Badge */}
      <span class="inline-block rounded-full bg-emerald-500/20 px-4 py-1.5 text-sm font-semibold text-emerald-300 ring-1 ring-inset ring-emerald-500/30">
        {totalCount} {totalCount === 1 ? "listing" : "listings"} &middot; Updated {monthYear}
      </span>

      {/* H1 */}
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl">
        {h1Text}
      </h1>
    </div>
  </section>

  {/* ═══ Introduction (100-150 words) ══════════════════════════════ */}
  <section class="bg-white py-12">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <p class="text-lg leading-relaxed text-gray-700">
        {introText}
      </p>
    </div>
  </section>

  {/* ═══ Core Content — The Directory ══════════════════════════════ */}
  <section class="bg-gray-50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

      {totalCount === 0 ? (
        /* ── Empty / Coming Soon ───────────────────────────── */
        <div class="mx-auto max-w-lg rounded-2xl border-2 border-dashed border-gray-300 bg-white p-12 text-center">
          <svg class="mx-auto mb-4 h-16 w-16 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
          <h2 class="text-xl font-bold text-gray-900">Coming Soon</h2>
          <p class="mt-2 text-gray-500">
            We're curating the best {cat.label.toLowerCase()} in {city.name}.
            Check back soon!
          </p>
          <a
            href={`/${city.stateSlug}/${city.slug}`}
            class="mt-6 inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700"
          >
            Explore {city.name}
          </a>
        </div>
      ) : isMdx ? (
        /* ── MDX listings — responsive grid ───────────────── */
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {mdxPlaces.map((place, idx) => {
            const d = place.data;
            const placeUrl = `/places/${d.id}`;
            const bestFor = deriveBestFor(d.tags);
            const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${d.location.lat},${d.location.lng}`;
            return (
              <article class="group flex flex-col overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm transition hover:shadow-md">
                {/* Linked image */}
                <a href={placeUrl} class="relative aspect-4/3 overflow-hidden bg-gray-100">
                  {d.images[0] ? (
                    <img
                      src={d.images[0]}
                      alt={d.name}
                      loading={idx < 4 ? "eager" : "lazy"}
                      decoding="async"
                      class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
                    />
                  ) : (
                    <div class="flex h-full items-center justify-center text-gray-300">
                      <svg class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5z" /></svg>
                    </div>
                  )}
                  {/* Rating badge */}
                  {d.ratings.google_rating && (
                    <span class="absolute top-3 right-3 flex items-center gap-1 rounded-lg bg-white/90 px-2 py-1 text-xs font-bold text-gray-900 shadow-sm backdrop-blur-sm">
                      <span class="text-amber-500">&#9733;</span> {d.ratings.google_rating}
                    </span>
                  )}
                </a>

                <div class="flex flex-1 flex-col p-5">
                  {/* H2 listing name */}
                  <h2 class="text-lg font-bold text-gray-900 group-hover:text-emerald-700">
                    <a href={placeUrl}>
                      {idx + 1}. {d.name}
                    </a>
                  </h2>

                  {/* Meta line */}
                  <p class="mt-1 text-sm text-gray-500">
                    {d.sub_category} &middot; {d.location.address || `${city.name}, ${d.location.state}`}
                  </p>

                  {/* Key details */}
                  <div class="mt-3 space-y-1.5 text-sm">
                    {d.entry_fees.indian_inr && (
                      <div class="flex items-center gap-2 text-gray-600">
                        <svg class="h-4 w-4 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>
                        {d.entry_fees.indian_inr}
                      </div>
                    )}
                    <div class="flex items-center gap-2 text-gray-600">
                      <svg class="h-4 w-4 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>
                      {bestFor.join(", ")}
                    </div>
                    <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-emerald-600 hover:text-emerald-700">
                      <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
                      Open in Maps
                    </a>
                  </div>

                  {/* Tags */}
                  <div class="mt-auto flex flex-wrap gap-1.5 pt-4">
                    {d.tags.slice(0, 3).map((tag: string) => (
                      <span class="rounded-full bg-gray-50 px-2.5 py-0.5 text-xs font-medium text-gray-600">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      ) : (
        /* ── Google listings — responsive grid ────────────── */
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {googlePlaces.map((place, idx) => {
            const bestFor = deriveBestForGoogle(place.types);
            const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${place.lat},${place.lng}`;
            return (
              <article class="group flex flex-col overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm transition hover:shadow-md">
                {/* Image */}
                <div class="relative aspect-4/3 overflow-hidden bg-gray-100">
                  {place.photos[0] ? (
                    <img
                      src={place.photos[0]}
                      alt={place.name}
                      loading={idx < 4 ? "eager" : "lazy"}
                      decoding="async"
                      class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
                    />
                  ) : (
                    <div class="flex h-full items-center justify-center text-gray-300">
                      <svg class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5z" /></svg>
                    </div>
                  )}
                  {/* Rating badge */}
                  {place.rating > 0 && (
                    <span class="absolute top-3 right-3 flex items-center gap-1 rounded-lg bg-white/90 px-2 py-1 text-xs font-bold text-gray-900 shadow-sm backdrop-blur-sm">
                      <span class="text-amber-500">&#9733;</span> {place.rating}
                    </span>
                  )}
                </div>

                <div class="flex flex-1 flex-col p-5">
                  {/* H2 listing name */}
                  <h2 class="text-lg font-bold text-gray-900 group-hover:text-emerald-700">
                    {idx + 1}. {place.name}
                  </h2>

                  {/* Meta line */}
                  <p class="mt-1 text-sm text-gray-500">
                    {cat.label} &middot; {place.address || city.name}
                  </p>

                  {/* Key details */}
                  <div class="mt-3 space-y-1.5 text-sm">
                    {place.reviewCount > 0 && (
                      <div class="flex items-center gap-2 text-gray-600">
                        <svg class="h-4 w-4 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" /></svg>
                        {place.reviewCount.toLocaleString()} reviews
                      </div>
                    )}
                    <div class="flex items-center gap-2 text-gray-600">
                      <svg class="h-4 w-4 flex-shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>
                      {bestFor.join(", ")}
                    </div>
                    <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-emerald-600 hover:text-emerald-700">
                      <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
                      Open in Maps
                    </a>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      )}
    </div>
  </section>

  {/* ═══ Dynamic FAQ Section (Featured Snippets) ═══════════════════ */}
  <section class="bg-white py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900">
        Frequently Asked Questions
      </h2>
      <p class="mt-2 mb-8 text-gray-500">
        Common questions about {cat.label.toLowerCase()} in {city.name}.
      </p>

      <div class="divide-y divide-gray-200">
        {faqItems.map((faq) => (
          <details class="group py-5">
            <summary class="flex cursor-pointer items-center justify-between text-left font-semibold text-gray-900 group-open:text-emerald-700">
              <h3 class="text-base">{faq.q}</h3>
              <svg class="ml-4 h-5 w-5 flex-shrink-0 text-gray-400 transition group-open:rotate-180 group-open:text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-3 text-gray-600 leading-relaxed">
              {faq.a}
            </p>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* ═══ Internal Linking Footer — "The Near Me Web" ═══════════════ */}
  <section class="bg-gray-50 py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

      {/* Part 1: Explore more in {City} */}
      <div class="mb-10">
        <h2 class="mb-4 text-xl font-bold text-gray-900">
          Explore more in {city.name}
        </h2>
        <div class="flex flex-wrap gap-3">
          {otherCategories.map((c) => (
            <a
              href={`/${city.stateSlug}/${city.slug}/${c.slug}`}
              class="rounded-full border border-gray-200 bg-white px-5 py-2.5 text-sm font-medium text-gray-700 shadow-sm transition hover:border-emerald-300 hover:text-emerald-700 hover:shadow-md"
            >
              {c.label} in {city.name}
            </a>
          ))}
        </div>
      </div>

      {/* Part 2: Explore {Category} in nearby cities */}
      <div>
        <h2 class="mb-4 text-xl font-bold text-gray-900">
          Explore {cat.label} in nearby cities
        </h2>
        <div class="flex flex-wrap gap-3">
          {nearbyCities.map((nc) => (
            <a
              href={`/${nc.stateSlug}/${nc.slug}/${cat.slug}`}
              class="rounded-full border border-gray-200 bg-white px-5 py-2.5 text-sm font-medium text-gray-700 shadow-sm transition hover:border-emerald-300 hover:text-emerald-700 hover:shadow-md"
            >
              {cat.label} in {nc.name}
            </a>
          ))}
        </div>
      </div>

    </div>
  </section>

</BaseLayout>
