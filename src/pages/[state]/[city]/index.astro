---
export const prerender = true;
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PlaceCard from "../../../components/PlaceCard.astro";
import {
  cities,
  categories,
  getMdxPlacesForCity,
  getGooglePlacesForCity,
  type PseoCity,
  type PseoCategory,
  type GooglePlace,
} from "../../../lib/near-me";
import pseoPlacesData from "../../../data/pseo-places.json";

/* ------------------------------------------------------------------ */
/*  getStaticPaths — one page per city (18 total)                      */
/* ------------------------------------------------------------------ */

export async function getStaticPaths() {
  const allPlaces = await getCollection("places");
  const paths: any[] = [];

  for (const city of cities) {
    // Compute counts per category for the summary cards
    const categoryCounts: { cat: PseoCategory; count: number }[] = [];

    for (const cat of categories) {
      let count = 0;
      if (cat.source === "mdx") {
        count = getMdxPlacesForCity(allPlaces, city, cat).length;
      } else {
        count = getGooglePlacesForCity(pseoPlacesData, city.slug, cat.slug).length;
      }
      categoryCounts.push({ cat, count });
    }

    // Grab a few top MDX places for a "highlights" preview
    const allCat = categories.find((c) => c.slug === "tourist-places")!;
    const topPlaces = getMdxPlacesForCity(allPlaces, city, allCat)
      .sort((a, b) => (b.data.ratings.google_rating ?? 0) - (a.data.ratings.google_rating ?? 0))
      .slice(0, 3);

    paths.push({
      params: { state: city.stateSlug, city: city.slug },
      props: { city, categoryCounts, topPlaces },
    });
  }

  return paths;
}

/* ------------------------------------------------------------------ */
/*  Page props                                                         */
/* ------------------------------------------------------------------ */

const { city, categoryCounts, topPlaces } = Astro.props as {
  city: PseoCity;
  categoryCounts: { cat: PseoCategory; count: number }[];
  topPlaces: any[];
};

const totalCount = categoryCounts.reduce((sum, c) => sum + c.count, 0);

