  sightseeing: "M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z M15 12a3 3 0 11-6 0 3 3 0 016 0z",
  cafes: "M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.871c1.355 0 2.697.056 4.024.166C17.155 8.51 18 9.473 18 10.608v2.513M15 8.25v-1.5m-6 1.5v-1.5m12 9.75l-1.5.75a3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0L3 16.5m15-3.379a48.474 48.474 0 00-6-.371c-2.032 0-4.034.126-6 .371m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.169c0 .621-.504 1.125-1.125 1.125H4.125A1.125 1.125 0 013 20.625v-5.17c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 016 13.12M12.265 3.11a.375.375 0 11-.53 0L12 2.845l.265.265z",
  eateries: "M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.871c1.355 0 2.697.056 4.024.166C17.155 8.51 18 9.473 18 10.608v2.513m0 0V21m-8.998-4.758a48.308 48.308 0 005.996 0m-5.996 0A48.474 48.474 0 016 13.12M18 13.12A48.474 48.474 0 0012 12.75c-2.032 0-4.034.126-6 .371",
  "sweet-shops": "M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.871c1.355 0 2.697.056 4.024.166C17.155 8.51 18 9.473 18 10.608v2.513M15 8.25v-1.5m-6 1.5v-1.5m12 9.75l-1.5.75a3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0L3 16.5",
  lounges: "M9 9l10.5-3m0 6.553v3.75a2.25 2.25 0 01-1.632 2.163l-1.32.377a1.803 1.803 0 11-.99-3.467l2.31-.66a2.25 2.25 0 001.632-2.163zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 01-1.632 2.163l-1.32.377a1.803 1.803 0 01-.99-3.467l2.31-.66A2.25 2.25 0 009 15.553z",
};
---

<BaseLayout
  title={`Explore ${city.name}, ${city.state} — Northeast Explorer`}
  description={`Discover the best tourist places, cafes, eateries, and more in ${city.name}, ${city.state}. ${totalCount} listings with ratings and reviews.`}
>

  {/* ═══ Hero ══════════════════════════════════════════════════════ */}
  <section class="relative overflow-hidden bg-gray-900 py-16 sm:py-24">
    {topPlaces[0]?.data.images[0] && (
      <img
        src={topPlaces[0].data.images[0]}
        alt={city.name}
        class="absolute inset-0 h-full w-full object-cover opacity-25"
      />
    )}
    <div class="absolute inset-0 bg-gradient-to-r from-gray-900/95 to-gray-900/60" />

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      {/* Breadcrumb */}
      <nav class="mb-8 flex items-center gap-2 text-sm text-gray-400">
        <a href="/" class="hover:text-white">Home</a>
        <span>/</span>
        <a href="/states" class="hover:text-white">States</a>
        <span>/</span>
        <a href={`/states/${city.stateSlug}`} class="hover:text-white">{city.state}</a>
        <span>/</span>
        <span class="text-white">{city.name}</span>
      </nav>

      <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">
        Explore {city.name}
      </h1>
      <p class="mt-3 max-w-2xl text-lg text-gray-300">
        Discover the best places to visit, eat, and unwind in {city.name}, {city.state}.
      </p>
    </div>
  </section>

  {/* ═══ Category Grid ═════════════════════════════════════════════ */}
  <section class="bg-gray-50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-2xl font-bold text-gray-900">
        What are you looking for?
      </h2>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {categoryCounts.map(({ cat, count }) => (
          <a
            href={`/${city.stateSlug}/${city.slug}/${cat.slug}`}
            class="group relative overflow-hidden rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition hover:border-emerald-300 hover:shadow-md"
          >
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600 transition group-hover:bg-emerald-100">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={CATEGORY_ICONS[cat.slug] || CATEGORY_ICONS["tourist-places"]} />
              </svg>
            </div>

            <h3 class="text-lg font-bold text-gray-900 group-hover:text-emerald-700">
              {cat.label}
            </h3>
            <p class="mt-1 text-sm text-gray-500">
              {count > 0
                ? `${count} ${count === 1 ? "listing" : "listings"}`
                : "Coming soon"}
            </p>

            <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-emerald-600 group-hover:text-emerald-700">
              Browse
              <svg class="h-4 w-4 transition group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ═══ Top Places Preview ════════════════════════════════════════ */}
  {topPlaces.length > 0 && (
    <section class="bg-white py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mb-8 flex items-center justify-between">
          <h2 class="text-2xl font-bold text-gray-900">
            Top-rated in {city.name}
          </h2>
          <a
            href={`/${city.stateSlug}/${city.slug}/tourist-places`}
            class="text-sm font-semibold text-emerald-600 hover:text-emerald-700"
          >
            View all &rarr;
          </a>
        </div>

        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {topPlaces.map((place) => (
            <PlaceCard
              id={place.id}
              name={place.data.name}
              category={place.data.category}
              subCategory={place.data.sub_category}
              state={place.data.location.state}
              googleRating={place.data.ratings.google_rating}
              reviewsCount={place.data.ratings.google_reviews_count}
              tags={place.data.tags}
              image={place.data.images[0]}
              logistics={place.data.logistics}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  {/* ═══ Back to state ═════════════════════════════════════════════ */}
  <div class="bg-gray-50 py-8">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <a
        href={`/states/${city.stateSlug}`}
        class="inline-flex items-center gap-2 text-sm font-semibold text-emerald-600 hover:text-emerald-700"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        All places in {city.state}
      </a>
    </div>
  </div>

</BaseLayout>
