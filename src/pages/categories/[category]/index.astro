---
export const prerender = true;
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PlaceCard from "../../../components/PlaceCard.astro";
import { CATEGORIES, getCategoryBySlug, matchCategory, NE_STATES } from "../../../data/categories";

export async function getStaticPaths() {
  const allPlaces = await getCollection("places");

  return CATEGORIES.map((cat) => {
    const places = allPlaces.filter(
      (p) => matchCategory(p.data.category) === cat.slug
    );
    return {
      params: { category: cat.slug },
      props: { cat, places },
    };
  });
}

const { cat, places } = Astro.props;

function stateSlug(s: string) {
  return s.toLowerCase().replace(/\s+/g, "-");
}

// States that actually have places in this category
const statesWithPlaces = [...new Set(
  places.map((p) => p.data.location?.state ?? p.data.state ?? "").filter(Boolean)
)].sort();

// Sort places by rating desc
const sorted = [...places].sort(
  (a, b) => (b.data.ratings?.google_rating ?? 0) - (a.data.ratings?.google_rating ?? 0)
);

const title = `Top ${cat.label} in Northeast India — Axomor`;
const description = `${cat.description} Browse all ${places.length} ${cat.label.toLowerCase()} across the 8 sister states.`;
---

<BaseLayout title={title} description={description} image={cat.img}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": title,
    "description": description,
    "url": `https://axomor.com/categories/${cat.slug}`,
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://axomor.com" },
        { "@type": "ListItem", "position": 2, "name": "Categories", "item": "https://axomor.com/categories" },
        { "@type": "ListItem", "position": 3, "name": cat.label, "item": `https://axomor.com/categories/${cat.slug}` },
      ],
    },
  })} />

  {/* ── Hero Banner ──────────────────────────────────────── */}
  <section style="position: relative; height: 65vh; min-height: 420px; overflow: hidden;">
    <picture>
      <source srcset={cat.img.replace(/\.(jpe?g|png)$/i, ".webp")} type="image/webp" />
      <img
        src={cat.img}
        alt={cat.label}
        loading="eager"
        fetchpriority="high"
        width="1200"
        height="800"
        style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;"
      />
    </picture>
    <div style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(11,54,32,0.97) 0%, rgba(11,54,32,0.82) 30%, rgba(11,54,32,0.48) 60%, rgba(11,54,32,0.18) 100%);"></div>
    <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(0,0,0,0.50) 0%, transparent 38%);"></div>
    <div style="position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, #8B5E1A, #C4892A, #D4A843, #C4892A, #8B5E1A);"></div>

    <div style="position: relative; height: 100%; display: flex; align-items: flex-end;">
      <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8" style="padding-bottom: 3.5rem;">
        {/* Breadcrumb */}
        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem;">
          <a href="/" style="font-size: 0.75rem; color: rgba(212,168,67,0.65); font-family: 'Outfit', sans-serif; text-decoration: none;">Home</a>
          <span style="color: rgba(212,168,67,0.35); font-size: 0.75rem;">›</span>
          <a href="/categories" style="font-size: 0.75rem; color: rgba(212,168,67,0.65); font-family: 'Outfit', sans-serif; text-decoration: none;">Categories</a>
          <span style="color: rgba(212,168,67,0.35); font-size: 0.75rem;">›</span>
          <span style="font-size: 0.75rem; color: #D4A843; font-family: 'Outfit', sans-serif;">{cat.label}</span>
        </div>

        <h1 style="font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 400; color: #F9F4EC; line-height: 1.1; margin-bottom: 0.875rem;">
          Top {cat.label}<br /><em style="font-style: italic; color: #D4A843; font-weight: 300;">in Northeast India</em>
        </h1>
        <p style="font-size: 1rem; color: rgba(249,244,236,0.65); font-family: 'Outfit', sans-serif; font-weight: 300; max-width: 540px; line-height: 1.7; margin-bottom: 1.25rem;">
          {cat.tagline} — {places.length} places across 8 states.
        </p>

        {/* State filter pills */}
        <div class="flex flex-wrap gap-2">
          <a href={`/categories/${cat.slug}`}
             style="border: 1.5px solid rgba(212,168,67,0.55); background: rgba(212,168,67,0.18); color: #D4A843; border-radius: 9999px; padding: 0.35rem 1rem; font-size: 0.8125rem; font-weight: 600; font-family: 'Outfit', sans-serif; text-decoration: none;">
            All States
          </a>
          {statesWithPlaces.map((s) => (
            <a href={`/categories/${cat.slug}/${stateSlug(s)}`}
               style="border: 1px solid rgba(196,137,42,0.35); background: rgba(196,137,42,0.10); color: rgba(212,168,67,0.85); border-radius: 9999px; padding: 0.35rem 1rem; font-size: 0.8125rem; font-weight: 500; font-family: 'Outfit', sans-serif; text-decoration: none; transition: background 0.15s;"
               class="filter-pill">
              {s}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* ── Places Grid ─────────────────────────────────────── */}
  <section style="background: #F2EAD6; padding: 4rem 0 6rem;">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

      {/* Count + description */}
      <div style="margin-bottom: 2.5rem; max-width: 640px;">
        <p style="font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: #6B4A12; font-family: 'Outfit', sans-serif; margin-bottom: 0.75rem;">
          {places.length} places found
        </p>
        <p style="font-size: 0.9375rem; color: rgba(28,18,8,0.62); font-family: 'Outfit', sans-serif; line-height: 1.75;">
          {cat.description}
        </p>
      </div>

      {sorted.length > 0 ? (
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {sorted.map((place, i) => (
            <div class="reveal" style={`animation-delay: ${(i % 8) * 0.06}s;`}>
              <PlaceCard
                id={place.id}
                name={place.data.name}
                category={place.data.category}
                subCategory={place.data.sub_category ?? ""}
                state={place.data.location?.state ?? ""}
                googleRating={place.data.ratings?.google_rating ?? null}
                reviewsCount={place.data.ratings?.google_reviews_count ?? null}
                tags={place.data.tags ?? []}
                image={place.data.images?.[0] ?? ""}
                logistics={place.data.logistics ?? []}
              />
            </div>
          ))}
        </div>
      ) : (
        <p style="font-family: 'Outfit', sans-serif; color: rgba(28,18,8,0.45); font-size: 1rem;">
          No places found in this category yet.
        </p>
      )}

      {/* ── Browse this category by state (SEO internal links) ── */}
      {statesWithPlaces.length > 1 && (
        <div style="margin-top: 5rem; padding-top: 3rem; border-top: 1px solid rgba(196,137,42,0.20);">
          <div class="flex items-center gap-3 mb-6">
            <div style="width: 2rem; height: 1px; background: linear-gradient(90deg, transparent, #C4892A);"></div>
            <p style="font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: #6B4A12; font-family: 'Outfit', sans-serif;">
              Browse by State
            </p>
          </div>
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
            {statesWithPlaces.map((s) => {
              const stateCount = places.filter(
                (p) => (p.data.location?.state ?? p.data.state) === s
              ).length;
              return (
                <a
                  href={`/categories/${cat.slug}/${stateSlug(s)}`}
                  style="display: flex; align-items: center; justify-content: space-between; background: rgba(255,255,255,0.55); border: 1px solid rgba(196,137,42,0.18); border-radius: 10px; padding: 1rem 1.125rem; text-decoration: none; transition: background 0.15s, border-color 0.15s;"
                  class="state-link"
                >
                  <span style="font-family: 'Cormorant Garamond', serif; font-size: 1.0625rem; font-weight: 500; color: #1C1208;">
                    {cat.label.split(" ")[0]} in {s}
                  </span>
                  <span style="font-size: 0.75rem; font-weight: 600; color: #C4892A; font-family: 'Outfit', sans-serif; background: rgba(196,137,42,0.10); border-radius: 9999px; padding: 0.125rem 0.5rem;">
                    {stateCount}
                  </span>
                </a>
              );
            })}
          </div>
        </div>
      )}
    </div>
  </section>

  <style>
    .filter-pill:hover { background: rgba(196,137,42,0.18) !important; }
    .state-link:hover { background: rgba(255,255,255,0.82) !important; border-color: rgba(196,137,42,0.35) !important; }
  </style>

</BaseLayout>
