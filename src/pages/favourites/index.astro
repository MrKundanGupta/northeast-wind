---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Favourites — Axomor" description="Your saved favourite places across Northeast India.">
  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">

    <div class="mb-8 flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">My Favourites</h1>
        <p class="mt-1 text-sm text-gray-500">Places you've saved across Northeast India.</p>
      </div>
      <button
        data-plan-trip
        class="hidden sm:flex items-center gap-2 rounded-xl bg-emerald-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-emerald-700 transition"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
        </svg>
        Plan My Trip
      </button>
    </div>

    <div id="favourites-root"></div>

  </div>
</BaseLayout>

<script>
  import { loadFavouritesFromStorage, $favourites, removeFavourite } from '../../stores/favourites';

  loadFavouritesFromStorage();

  function render() {
    const places = $favourites.get();
    const root = document.getElementById('favourites-root');
    if (!root) return;

    if (places.length === 0) {
      root.innerHTML = `
        <div class="flex flex-col items-center py-24 text-center">
          <svg class="mb-4 h-16 w-16 text-gray-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
          </svg>
          <h2 class="text-lg font-semibold text-gray-900">No favourites yet</h2>
          <p class="mt-2 text-sm text-gray-500 max-w-xs">Tap the heart icon on any place card to save it here.</p>
          <a href="/states" class="mt-6 rounded-xl bg-emerald-600 px-6 py-2.5 text-sm font-semibold text-white hover:bg-emerald-700 transition">
            Browse Places
          </a>
        </div>`;
      return;
    }

    root.innerHTML = `
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        ${places.map(p => `
          <div class="group flex flex-col overflow-hidden rounded-2xl border bg-white shadow-sm hover:shadow-md transition" style="border-color: #E8DCC8;">
            <a href="/places/${p.id}" class="block relative" style="aspect-ratio: 16/10; overflow: hidden; background: #EDE0C8;">
              ${p.image
                ? `<img src="${p.image}" alt="${p.name}" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />`
                : `<div class="flex h-full w-full items-center justify-center bg-emerald-100"><svg class="h-10 w-10 text-emerald-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91" /></svg></div>`
              }
              <div style="position:absolute;inset:0;background:linear-gradient(to top, rgba(11,54,32,0.45) 0%, transparent 55%);pointer-events:none;"></div>
              <span class="absolute top-3 left-3 rounded-full bg-emerald-600/90 px-2.5 py-0.5 text-[11px] font-semibold uppercase tracking-wide text-white backdrop-blur-sm">${p.category}</span>
              ${p.googleRating ? `<span class="absolute top-3 right-3 flex items-center gap-1 rounded-full bg-amber-500/90 px-2 py-0.5 text-xs font-bold text-white backdrop-blur-sm">★ ${p.googleRating}</span>` : ''}
            </a>
            <div class="flex flex-1 items-start justify-between p-4">
              <div class="min-w-0">
                <a href="/places/${p.id}" class="block text-base font-semibold text-gray-900 hover:text-emerald-700 transition truncate leading-tight">${p.name}</a>
                <p class="mt-0.5 text-xs text-gray-500">${p.category} · ${p.state}</p>
              </div>
              <button data-remove="${p.id}" class="ml-3 flex-shrink-0 rounded-full p-1.5 text-rose-300 hover:bg-rose-50 hover:text-rose-500 transition" aria-label="Remove from favourites">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                </svg>
              </button>
            </div>
          </div>
        `).join('')}
      </div>`;

    root.querySelectorAll('[data-remove]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const id = (btn as HTMLElement).dataset.remove!;
        removeFavourite(id);
      });
    });
  }

  render();
  $favourites.subscribe(render);
</script>
