---
export const prerender = true;
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PlaceCard from "../../components/PlaceCard.astro";

export async function getStaticPaths() {
  const allPlaces = await getCollection("places");
  const allHubCities = await getCollection("hubCities");

  const states = [
    ...new Set([
      ...allPlaces.map((p) => p.data.location.state),
      ...allHubCities.map((p) => p.data.location.state),
    ]),
  ];

  return states.map((state) => ({
    params: { state: state.toLowerCase().replace(/\s+/g, "-") },
    props: {
      stateName: state,
      places: allPlaces.filter((p) => p.data.location.state === state),
      hubCities: allHubCities.filter((p) => p.data.location.state === state),
    },
  }));
}

const { stateName, places, hubCities } = Astro.props;

const destinations = places;
---

<BaseLayout title={`${stateName} — Axomor · Northeast India`}>

  {/* ── Header ── */}
  <section style="background: #1E3D10; padding: 4rem 0 3rem;" class="tribal-pattern-dense">
    <div style="height: 2px; background: linear-gradient(90deg, #8B5E1A, #C4892A, #D4A843, #C4892A, #8B5E1A); margin-bottom: 3rem;"></div>
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

      {/* Breadcrumb */}
      <nav style="font-size: 0.75rem; color: rgba(249,244,236,0.45); font-family: 'Outfit', sans-serif; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem;">
        <a href="/" style="color: rgba(249,244,236,0.45); text-decoration: none; transition: color 0.15s ease;" class="breadcrumb-link">Home</a>
        <span>/</span>
        <a href="/states" style="color: rgba(249,244,236,0.45); text-decoration: none;" class="breadcrumb-link">States</a>
        <span>/</span>
        <span style="color: #D4A843;">{stateName}</span>
      </nav>

      <p style="font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #D4A843; margin-bottom: 0.75rem; font-family: 'Outfit', sans-serif;">
        Northeast India
      </p>
      <h1 style="font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 400; color: #F9F4EC; line-height: 1.1;">
        {stateName}
      </h1>
      <div style="width: 3rem; height: 1.5px; background: linear-gradient(90deg, #C4892A, transparent); margin-top: 1rem;"></div>
      <p style="margin-top: 0.75rem; font-size: 1rem; color: rgba(249,244,236,0.60); font-family: 'Outfit', sans-serif; font-weight: 300;">
        {destinations.length} destinations &mdash; {hubCities.length} hub cities
      </p>
    </div>
  </section>

  {/* ── Hub Cities — the spokes ── */}
  {hubCities.length > 0 && (
    <section style="background: #F9F4EC; padding: 4rem 0; border-bottom: 1px solid #E8DCC8;">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div style="margin-bottom: 2rem;">
          <p style="font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #C4892A; margin-bottom: 0.375rem; font-family: 'Outfit', sans-serif;">
            Hub & Spoke
          </p>
          <h2 style="font-family: 'Cormorant Garamond', serif; font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 500; color: #1C1208;">
            Hub Cities in {stateName}
          </h2>
          <div style="width: 3rem; height: 1.5px; background: linear-gradient(90deg, #C4892A, transparent); margin-top: 0.625rem;"></div>
          <p style="margin-top: 0.5rem; font-size: 0.875rem; color: #7A6555; font-family: 'Outfit', sans-serif;">
            Base yourself here to explore the surrounding region.
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {hubCities.map((hub) => (
            <a
              href={`/destinations/${hub.data.city.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`}
              class="hub-card group flex items-start gap-4 rounded-xl p-5"
              style="background: #ffffff; border: 1px solid #E8DCC8; box-shadow: 0 2px 12px rgba(28,18,8,0.06); text-decoration: none; transition: box-shadow 0.2s ease, transform 0.2s ease;"
            >
              {/* Icon */}
              <div style="flex-shrink: 0; width: 40px; height: 40px; background: #F2EAD6; border-radius: 10px; display: flex; align-items: center; justify-content: center; border: 1px solid #E8DCC8;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C4892A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                  <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
              </div>
              <div>
                <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 1.125rem; font-weight: 600; color: #1C1208; transition: color 0.15s ease;" class="hub-card-title">
                  {hub.data.name}
                </h3>
                <p style="margin-top: 0.25rem; font-size: 0.75rem; color: #7A6555; font-family: 'Outfit', sans-serif; line-height: 1.5;">
                  {hub.data.high_intent_motivation?.slice(0, 90)}…
                </p>
                <span style="display: inline-flex; align-items: center; gap: 0.25rem; margin-top: 0.5rem; font-size: 0.6875rem; font-weight: 600; color: #145C35; font-family: 'Outfit', sans-serif; letter-spacing: 0.02em;">
                  View places
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* ── All Destinations ── */}
  <section style="background: #F2EAD6; padding: 5rem 0;">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div style="margin-bottom: 2.5rem;">
        <p style="font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #C4892A; margin-bottom: 0.375rem; font-family: 'Outfit', sans-serif;">
          All Destinations
        </p>
        <h2 style="font-family: 'Cormorant Garamond', serif; font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 500; color: #1C1208;">
          Places to Visit in {stateName}
        </h2>
        <div style="width: 3rem; height: 1.5px; background: linear-gradient(90deg, #C4892A, transparent); margin-top: 0.625rem;"></div>
      </div>

      <div class="grid gap-7 sm:grid-cols-2 lg:grid-cols-3">
        {destinations.map((place) => (
          <PlaceCard
            id={place.id}
            name={place.data.name}
            category={place.data.category}
            subCategory={place.data.sub_category}
            state={place.data.location.state}
            googleRating={place.data.ratings.google_rating}
            reviewsCount={place.data.ratings.google_reviews_count}
            tags={place.data.tags}
            image={place.data.images[0]}
            logistics={place.data.logistics}
          />
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .breadcrumb-link:hover { color: #D4A843 !important; }
  .hub-card:hover { box-shadow: 0 8px 28px rgba(28,18,8,0.12) !important; transform: translateY(-2px); }
  .hub-card:hover .hub-card-title { color: #145C35 !important; }
</style>
