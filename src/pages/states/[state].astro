---
export const prerender = true;
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PlaceCard from "../../components/PlaceCard.astro";
import { cities } from "../../lib/near-me";
import cityImages from "../../data/city-images.json";

export async function getStaticPaths() {
  const places = await getCollection("places");
  const states = [...new Set(places.map((p) => p.data.location.state))];

  return states.map((state) => ({
    params: { state: state.toLowerCase().replace(/\s+/g, "-") },
    props: {
      stateName: state,
      stateSlug: state.toLowerCase().replace(/\s+/g, "-"),
      places: places.filter((p) => p.data.location.state === state),
    },
  }));
}

const { stateName, stateSlug, places } = Astro.props;

/* Cities in this state from the PSEO config */
const stateCities = cities.filter((c) => c.stateSlug === stateSlug);
const cityImagesMap = cityImages as Record<string, string>;
---

<BaseLayout title={`${stateName} — Northeast Explorer`}>
  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <nav class="mb-6 text-sm text-gray-500">
      <a href="/" class="hover:text-emerald-700">Home</a>
      <span class="mx-2">/</span>
      <a href="/states" class="hover:text-emerald-700">States</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">{stateName}</span>
    </nav>

    <h1 class="mb-2 text-3xl font-bold tracking-tight text-gray-900">{stateName}</h1>
    <p class="mb-8 text-lg text-gray-600">{places.length} destinations</p>

    {/* ── Cities to explore ──────────────────────────────────── */}
    {stateCities.length > 0 && (
      <section class="mb-12">
        <h2 class="mb-4 text-xl font-bold text-gray-900">Cities to Explore</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {stateCities.map((c) => {
            const img = cityImagesMap[c.slug];
            return (
              <a
                href={`/${c.stateSlug}/${c.slug}`}
                class="group relative overflow-hidden rounded-xl border border-gray-200 shadow-sm transition hover:shadow-md"
              >
                {img && (
                  <div class="relative h-36 w-full overflow-hidden">
                    <img
                      src={img}
                      alt={`${c.name} city`}
                      class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
                      loading="lazy"
                      decoding="async"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
                  </div>
                )}
                <div class="p-4">
                  <h3 class="text-lg font-semibold text-gray-900 group-hover:text-emerald-700">
                    {c.name}
                  </h3>
                  <p class="mt-1 text-sm text-gray-500">
                    Cafes, eateries, sightseeing & more
                  </p>
                  <span class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-emerald-600">
                    Explore
                    <svg class="h-4 w-4 transition group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    {/* ── All destinations ───────────────────────────────────── */}
    <h2 class="mb-4 text-xl font-bold text-gray-900">All Destinations</h2>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {places.map((place) => (
        <PlaceCard
          id={place.id}
          name={place.data.name}
          category={place.data.category}
          subCategory={place.data.sub_category}
          state={place.data.location.state}
          googleRating={place.data.ratings.google_rating}
          reviewsCount={place.data.ratings.google_reviews_count}
          tags={place.data.tags}
          image={place.data.images[0]}
          logistics={place.data.logistics}
        />
      ))}
    </div>
  </div>
</BaseLayout>
