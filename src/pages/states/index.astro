---
export const prerender = true;
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const allPlaces = await getCollection("places");
const allHubCities = await getCollection("hubCities");

const stateMap = new Map<string, number>();
for (const place of [...allPlaces, ...allHubCities]) {
  const state = place.data.location.state;
  stateMap.set(state, (stateMap.get(state) || 0) + 1);
}
const states = [...stateMap.entries()].sort((a, b) => a[0].localeCompare(b[0]));

// Local images — same source as homepage state cards
const STATE_META: Record<string, { img: string; tagline: string }> = {
  "Assam": {
    img: "/images/assam/kaziranga-national-park/1.jpg",
    tagline: "Tea gardens, wild rhinos & the mighty Brahmaputra",
  },
  "Meghalaya": {
    img: "/images/meghalaya/nohkalikai-falls/1.jpg",
    tagline: "Living root bridges, deep caves & sacred waterfalls",
  },
  "Sikkim": {
    img: "/images/sikkim/tsomgo-lake/1.jpg",
    tagline: "Himalayan monasteries, alpine lakes & Kanchenjunga",
  },
  "Arunachal Pradesh": {
    img: "/images/arunachal-pradesh/tawang-monastery/1.jpg",
    tagline: "Remote peaks, tribal valleys & ancient monasteries",
  },
  "Nagaland": {
    img: "/images/nagaland/dzukou-valley/1.jpg",
    tagline: "Hornbill festival, tribal heritage & Dzukou Valley",
  },
  "Manipur": {
    img: "/images/manipur/loktak-lake/1.png",
    tagline: "Loktak's floating islands, Kangla Fort & rare Sangai",
  },
  "Mizoram": {
    img: "/images/mizoram/vantawng-falls/1.jpg",
    tagline: "Blue hills, bamboo forests & ancient Mizo traditions",
  },
  "Tripura": {
    img: "/images/tripura/neermahal/1.jpg",
    tagline: "Unakoti rock carvings, Neermahal palace & wildlife",
  },
};
const FALLBACK = { img: "/images/nagaland/dzukou-valley/1.jpg", tagline: "Explore unique destinations" };
---

<BaseLayout title="Browse by State — Axomor · Northeast India">

  {/* ── Page Header ─────────────────────────────────────── */}
  <section style="background: #1E3D10; position: relative; padding: 5rem 0 4rem; overflow: hidden;" class="tribal-pattern-dense">

    {/* Ambient glow */}
    <div style="position: absolute; top: -80px; right: -80px; width: 400px; height: 400px; border-radius: 50%; background: radial-gradient(circle, rgba(196,137,42,0.14) 0%, transparent 65%); pointer-events: none;"></div>

    <div style="height: 2px; background: linear-gradient(90deg, #6B4A12, #8B5E1A, #C4892A, #D4A843, #C4892A, #8B5E1A, #6B4A12); margin-bottom: 3.5rem;"></div>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative" style="z-index: 1;">
      <div class="flex items-center gap-3 mb-5">
        <div style="width: 2rem; height: 1px; background: linear-gradient(90deg, transparent, #D4A843);"></div>
        <p style="font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: #D4A843; font-family: 'Outfit', sans-serif;">
          The Eight Sister States
        </p>
      </div>
      <h1 style="font-family: 'Cormorant Garamond', serif; font-size: clamp(2.25rem, 6vw, 4rem); font-weight: 300; color: #F9F4EC; line-height: 1.0; letter-spacing: -0.02em; margin-bottom: 1.25rem;">
        Eight <em style="font-style: italic; color: #D4A843; font-weight: 400;">Extraordinary</em><br />States of India
      </h1>
      <div style="display: flex; align-items: center; gap: 0.875rem; margin-bottom: 1.25rem;">
        <div style="width: 3rem; height: 1.5px; background: linear-gradient(90deg, #C4892A, #D4A843);"></div>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="rgba(212,168,67,0.75)">
          <path d="M12 2L14 9L21 12L14 15L12 22L10 15L3 12L10 9Z"/>
        </svg>
        <div style="width: 3rem; height: 1.5px; background: linear-gradient(90deg, #D4A843, #C4892A);"></div>
      </div>
      <p style="font-size: 1rem; color: rgba(249,244,236,0.58); font-family: 'Outfit', sans-serif; font-weight: 300; max-width: 500px; line-height: 1.75;">
        Each state is a universe — ancient traditions, untouched wilderness, and landscapes that defy description. Pick one to begin.
      </p>
    </div>
  </section>

  {/* ── State Grid ──────────────────────────────────────── */}
  <section style="background: #F2EAD6; padding: 5rem 0 6rem;">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {states.map(([state, count], i) => {
          const meta = STATE_META[state] ?? FALLBACK;
          return (
            <a
              href={`/states/${state.toLowerCase().replace(/\s+/g, "-")}`}
              class={`state-img-card reveal`}
              style={`aspect-ratio: 3/4; animation-delay: ${i * 0.07}s;`}
            >
              <picture>
                <source srcset={meta.img.replace(/\.(jpe?g|png)$/i, '-sm.webp')} type="image/webp" />
                <img src={meta.img} alt={`${state} — Northeast India`} loading="lazy" decoding="async" width="320" height="427" />
              </picture>
              <div class="card-overlay"></div>

              {/* Destination count pill at top */}
              <span style="position: absolute; top: 1rem; left: 1rem; background: rgba(11,54,32,0.82); color: rgba(212,168,67,0.90); font-family: 'Outfit', sans-serif; font-size: 0.625rem; font-weight: 700; letter-spacing: 0.10em; text-transform: uppercase; border-radius: 9999px; padding: 0.25rem 0.75rem; backdrop-filter: blur(8px);">
                {count} destinations
              </span>

              <div class="card-content">
                <h2 style="font-family: 'Cormorant Garamond', serif; font-size: clamp(1.25rem, 2.5vw, 1.5rem); font-weight: 500; color: #F9F4EC; line-height: 1.1; margin-bottom: 0.5rem;">
                  {state}
                </h2>
                <p style="font-size: 0.75rem; color: rgba(249,244,236,0.62); font-family: 'Outfit', sans-serif; font-weight: 300; line-height: 1.5; margin-bottom: 0.75rem;">
                  {meta.tagline}
                </p>
                <div class="explore-arrow">
                  <span>Explore</span>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                  </svg>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

</BaseLayout>
