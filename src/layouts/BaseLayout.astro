---
import "../styles/global.css";
import CartToggleButton from "../components/CartToggleButton";
import TripSidebar from "../components/TripSidebar";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "Explore the best destinations across Northeast India", image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, 'https://axomor.com').href;
const ogImage = image ?? 'https://axomor.com/logo_full.png';

const navLinks = [
  { href: "/",       label: "All Places",   icon: "M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" },
  { href: "/states", label: "By State",     icon: "M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" },
  { href: "/plan",   label: "Plan Trip",    icon: "M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" },
  { href: "/map",    label: "Map",          icon: "M9 3v14l6-4 6 4V3M9 3H3v14l6-4" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <!-- Google Tag Manager — deferred after window load to protect LCP/TBT scores.
         dataLayer is initialised immediately so pushes before load are queued. -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      window.addEventListener('load', function () {
        var run = function () {
          (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
          new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
          j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
          'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
          })(window,document,'script','dataLayer','GTM-WQNJDC4L');
        };
        'requestIdleCallback' in window ? requestIdleCallback(run) : setTimeout(run, 1000);
      });
    </script>
    <!-- End Google Tag Manager -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" href="/favicon.png" sizes="32x32" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Axomor" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
    <!-- Google Fonts — non-blocking (preconnect + deferred stylesheet) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=Outfit:wght@300;400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=Outfit:wght@300;400;500;600;700&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=Outfit:wght@300;400;500;600;700&display=swap" /></noscript>
    <slot name="head" />
  </head>

  <body class="min-h-screen antialiased" style="background-color: #F9F4EC; color: #1C1208; font-family: 'Outfit', system-ui, sans-serif;">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WQNJDC4L"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    {/* ── Navigation ─────────────────────────────────────────────── */}
    {/*
      Color rationale: logo greens are #2A4F1E (dark) and #488728 (medium).
      Using #1E3D10 — darker than logo's dark mountain, warm enough to feel cohesive.
      Previous #0B3620 was too cold and disconnected from the logo palette.
    */}
    <nav id="main-nav" style="background: #1E3D10; border-bottom: 1px solid rgba(196,137,42,0.22); position: sticky; top: 0; z-index: 200;">
      {/* Tribal gold accent line — top */}
      <div style="height: 2.5px; background: linear-gradient(90deg, transparent, #8B5E1A 15%, #C4892A 35%, #D4A843 50%, #C4892A 65%, #8B5E1A 85%, transparent);"></div>

      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between" style="height: 64px;">

          {/* ── Logo ── */}
          <a href="/" style="text-decoration: none; flex-shrink: 0; display: inline-flex; align-items: center;">
            <div style="background: rgba(255,255,255,0.97); border-radius: 8px; padding: 5px 10px; display: inline-flex; align-items: center; box-shadow: 0 2px 8px rgba(0,0,0,0.12); transition: box-shadow 0.2s ease, transform 0.2s ease;" class="logo-wrap">
              <picture class="sm:hidden">
                <source srcset="/logo_icon.webp" type="image/webp" />
                <img src="/logo_icon.png" alt="Axomor" style="height: 30px; width: auto;" width="83" height="30" />
              </picture>
              <picture class="hidden sm:block">
                <source srcset="/logo_full.webp" type="image/webp" />
                <img src="/logo_full.png" alt="AXOMOR" style="height: 28px; width: auto;" width="77" height="28" />
              </picture>
            </div>
          </a>

          {/* ── Desktop links ── */}
          <div class="hidden sm:flex items-center gap-0.5">
            {navLinks.map(({ href, label }) => (
              <a href={href} class="nav-link"
                 style="color: rgba(249,244,236,0.74); font-family: 'Outfit', sans-serif; font-size: 0.875rem; font-weight: 500; letter-spacing: 0.01em; text-decoration: none; padding: 0.5rem 0.875rem; border-radius: 9999px; transition: color 0.18s ease, background 0.18s ease;">
                {label}
              </a>
            ))}

            <div style="width: 1px; height: 18px; background: rgba(196,137,42,0.28); margin: 0 0.625rem;"></div>

            <CartToggleButton client:idle />
          </div>

          {/* ── Mobile: cart + hamburger ── */}
          <div class="flex sm:hidden items-center gap-2.5">
            <CartToggleButton client:idle />

            <button id="mobile-menu-btn"
                    aria-label="Open navigation menu"
                    aria-expanded="false"
                    style="width: 40px; height: 40px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 5px; background: rgba(255,255,255,0.10); border-radius: 8px; border: 1px solid rgba(196,137,42,0.25); cursor: pointer; padding: 0; transition: background 0.2s ease;">
              <span class="ham-line" style="width: 20px; height: 1.5px; background: #F9F4EC; border-radius: 2px; transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease; transform-origin: center;"></span>
              <span class="ham-line" style="width: 14px; height: 1.5px; background: #D4A843; border-radius: 2px; transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease; transform-origin: center;"></span>
              <span class="ham-line" style="width: 20px; height: 1.5px; background: #F9F4EC; border-radius: 2px; transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease; transform-origin: center;"></span>
            </button>
          </div>
        </div>
      </div>
    </nav>

    {/* ── Mobile Menu Full-Screen Overlay ────────────────────────── */}
    <div id="mobile-menu"
         aria-hidden="true"
         style="
           position: fixed; inset: 0; z-index: 199;
           background: #1A3610;
           opacity: 0; pointer-events: none;
           transition: opacity 0.35s cubic-bezier(0.22,1,0.36,1);
           overflow-y: auto;
         ">

      {/* Tribal pattern overlay */}
      <div class="tribal-pattern-dense" style="position: absolute; inset: 0; opacity: 0.3; pointer-events: none;"></div>

      {/* Gold ambient orbs */}
      <div style="position: absolute; top: -80px; right: -80px; width: 360px; height: 360px; border-radius: 50%; background: radial-gradient(circle, rgba(196,137,42,0.12) 0%, transparent 65%); pointer-events: none;"></div>
      <div style="position: absolute; bottom: -60px; left: -60px; width: 280px; height: 280px; border-radius: 50%; background: radial-gradient(circle, rgba(74,138,44,0.10) 0%, transparent 65%); pointer-events: none;"></div>

      {/* Content wrapper */}
      <div style="position: relative; z-index: 1; min-height: 100vh; display: flex; flex-direction: column; padding: 0 1.5rem 3rem;">

        {/* Top bar: logo + close */}
        <div style="height: 64px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(196,137,42,0.15);">
          <a href="/" style="text-decoration: none;">
            <div style="background: rgba(255,255,255,0.97); border-radius: 8px; padding: 5px 10px; display: inline-flex; align-items: center;">
              <picture>
                <source srcset="/logo_full.webp" type="image/webp" />
                <img src="/logo_full.png" alt="AXOMOR" style="height: 26px; width: auto;" width="72" height="26" />
              </picture>
            </div>
          </a>
          <button id="mobile-menu-close"
                  aria-label="Close navigation menu"
                  style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.08); border-radius: 8px; border: 1px solid rgba(196,137,42,0.20); cursor: pointer; color: #F9F4EC;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
          </button>
        </div>

        {/* Navigation links — big serif */}
        <nav style="flex: 1; display: flex; flex-direction: column; justify-content: center; padding: 2.5rem 0;">

          <p style="font-size: 0.625rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(196,137,42,0.75); font-family: 'Outfit', sans-serif; margin-bottom: 2rem;">
            Navigate
          </p>

          <div style="display: flex; flex-direction: column; gap: 0.25rem;">
            {navLinks.map(({ href, label }, i) => (
              <a href={href}
                 class="mobile-nav-item"
                 data-index={i}
                 style={`
                   text-decoration: none;
                   display: flex; align-items: center; gap: 1rem;
                   padding: 0.875rem 0;
                   border-bottom: 1px solid rgba(196,137,42,0.10);
                   opacity: 0; transform: translateX(-20px);
                   transition: opacity 0.4s ease ${i * 0.07 + 0.15}s, transform 0.4s ease ${i * 0.07 + 0.15}s, color 0.2s ease;
                 `}>
                <span style="font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 8vw, 2.5rem); font-weight: 400; color: rgba(249,244,236,0.90); line-height: 1; letter-spacing: -0.02em; transition: color 0.2s ease;" class="mobile-link-text">
                  {label}
                </span>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgba(212,168,67,0)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mobile-link-arrow" style="transition: stroke 0.2s ease, transform 0.2s ease; flex-shrink: 0;">
                  <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
              </a>
            ))}
          </div>

          {/* Divider */}
          <div style="display: flex; align-items: center; gap: 0.75rem; margin: 2rem 0 1.5rem;">
            <div style="flex: 1; height: 1px; background: linear-gradient(90deg, rgba(196,137,42,0.30), transparent);"></div>
            <svg width="10" height="10" viewBox="0 0 24 24" fill="rgba(196,137,42,0.55)"><path d="M12 2L14 9L21 12L14 15L12 22L10 15L3 12L10 9Z"/></svg>
            <div style="flex: 1; height: 1px; background: linear-gradient(90deg, transparent, rgba(196,137,42,0.30));"></div>
          </div>

          {/* Quick state links */}
          <div>
            <p style="font-size: 0.625rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(196,137,42,0.65); font-family: 'Outfit', sans-serif; margin-bottom: 1rem;">
              Quick · States
            </p>
            <div style="display: flex; flex-wrap: wrap; gap: 0.625rem;">
              {["Assam","Meghalaya","Sikkim","Arunachal Pradesh","Nagaland","Manipur","Mizoram","Tripura"].map(s => (
                <a href={`/states/${s.toLowerCase().replace(/\s+/g,"-")}`}
                   style="font-size: 0.8125rem; font-weight: 500; color: rgba(249,244,236,0.60); font-family: 'Outfit', sans-serif; text-decoration: none; background: rgba(255,255,255,0.06); border: 1px solid rgba(196,137,42,0.18); border-radius: 9999px; padding: 0.3rem 0.875rem; transition: background 0.2s, color 0.2s;" class="mobile-state-pill">
                  {s}
                </a>
              ))}
            </div>
          </div>
        </nav>

        {/* Bottom tagline */}
        <div style="border-top: 1px solid rgba(196,137,42,0.15); padding-top: 1.5rem; text-align: center;">
          <p style="font-family: 'Cormorant Garamond', serif; font-size: 1rem; font-weight: 300; font-style: italic; color: rgba(249,244,236,0.40);">
            "Where the hills meet the sky."
          </p>
        </div>
      </div>
    </div>

    <main>
      <slot />
    </main>

    {/* ── Footer ─────────────────────────────────────────────────── */}
    <footer style="background: #1A3610; border-top: 1px solid rgba(196,137,42,0.18); margin-top: 0;" class="tribal-pattern-dense">
      {/* Mountain silhouette */}
      <div style="overflow: hidden; line-height: 0;">
        <svg viewBox="0 0 1440 72" preserveAspectRatio="none" style="width: 100%; height: 72px; display: block;">
          <path d="M0,72 L0,52 L120,16 L200,42 L320,4 L440,40 L560,12 L660,44 L760,2 L880,38 L1000,14 L1100,46 L1200,18 L1320,44 L1440,24 L1440,72 Z" fill="rgba(196,137,42,0.08)"/>
        </svg>
      </div>
      <div style="height: 2px; background: linear-gradient(90deg, transparent, #8B5E1A 15%, #C4892A 35%, #D4A843 50%, #C4892A 65%, #8B5E1A 85%, transparent);"></div>

      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
        <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">

          {/* Brand */}
          <div class="lg:col-span-1">
            <div class="mb-5" style="display: inline-flex; background: rgba(255,255,255,0.08); border-radius: 8px; padding: 6px 12px; border: 1px solid rgba(196,137,42,0.18);">
              <picture>
                <source srcset="/logo_full.webp" type="image/webp" />
                <img src="/logo_full.png" alt="AXOMOR" style="height: 26px; width: auto; filter: brightness(0) invert(1);" width="72" height="26" />
              </picture>
            </div>
            <p style="font-size: 0.875rem; color: rgba(249,244,236,0.48); line-height: 1.75; font-family: 'Outfit', sans-serif; font-weight: 300; max-width: 220px;">
              Your guide to Northeast India's untouched wilderness, sacred peaks, and living cultures.
            </p>
            <div style="margin-top: 1.25rem; display: flex; align-items: center; gap: 0.625rem;">
              <div style="width: 1.5rem; height: 1px; background: rgba(196,137,42,0.35);"></div>
              <svg width="10" height="10" viewBox="0 0 24 24" fill="rgba(196,137,42,0.55)"><path d="M12 2L14 9L21 12L14 15L12 22L10 15L3 12L10 9Z"/></svg>
              <div style="width: 1.5rem; height: 1px; background: rgba(196,137,42,0.35);"></div>
            </div>
          </div>

          {/* Explore */}
          <div>
            <p style="font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: #C4892A; margin-bottom: 1.25rem; font-family: 'Outfit', sans-serif;">Explore</p>
            <div class="flex flex-col gap-2.5">
              {[{href:"/",label:"All Places"},{href:"/states",label:"By State"},{href:"/plan",label:"Plan by Hub"},{href:"/map",label:"Interactive Map"}].map(({href,label}) => (
                <a href={href} class="footer-link"
                   style="font-size: 0.875rem; color: rgba(249,244,236,0.55); font-family: 'Outfit', sans-serif; text-decoration: none; transition: color 0.15s ease; display: flex; align-items: center; gap: 0.5rem;">
                  <span class="footer-dot" style="width: 4px; height: 4px; border-radius: 50%; background: rgba(196,137,42,0.45); flex-shrink: 0; transition: background 0.15s ease;"></span>
                  {label}
                </a>
              ))}
            </div>
          </div>

          {/* States */}
          <div>
            <p style="font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: #C4892A; margin-bottom: 1.25rem; font-family: 'Outfit', sans-serif;">States</p>
            <div class="flex flex-col gap-2.5">
              {["Assam","Meghalaya","Sikkim","Arunachal Pradesh","Nagaland","Manipur"].map(s => (
                <a href={`/states/${s.toLowerCase().replace(/\s+/g,"-")}`} class="footer-link"
                   style="font-size: 0.875rem; color: rgba(249,244,236,0.55); font-family: 'Outfit', sans-serif; text-decoration: none; transition: color 0.15s ease; display: flex; align-items: center; gap: 0.5rem;">
                  <span class="footer-dot" style="width: 4px; height: 4px; border-radius: 50%; background: rgba(196,137,42,0.45); flex-shrink: 0; transition: background 0.15s ease;"></span>
                  {s}
                </a>
              ))}
            </div>
          </div>

          {/* Quote */}
          <div>
            <p style="font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-weight: 300; font-style: italic; color: rgba(249,244,236,0.62); line-height: 1.6;">
              "Where the hills meet the sky, and the rivers remember every name."
            </p>
            <div style="width: 2.5rem; height: 1.5px; background: linear-gradient(90deg, #C4892A, transparent); margin-top: 1.25rem;"></div>
            <p style="margin-top: 1rem; font-size: 0.75rem; color: rgba(249,244,236,0.28); font-family: 'Outfit', sans-serif;">
              Crafted with respect for the land and its people.
            </p>
          </div>
        </div>

        <div style="border-top: 1px solid rgba(196,137,42,0.10); margin-top: 3rem; padding-top: 1.5rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
          <p style="font-size: 0.75rem; color: rgba(249,244,236,0.28); font-family: 'Outfit', sans-serif;">
            &copy; {new Date().getFullYear()} Axomor &mdash; Northeast India Travel
          </p>
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <div style="width: 6px; height: 6px; border-radius: 50%; background: rgba(196,137,42,0.45);"></div>
            <div style="width: 6px; height: 6px; border-radius: 50%; background: rgba(196,137,42,0.25);"></div>
            <div style="width: 6px; height: 6px; border-radius: 50%; background: rgba(196,137,42,0.12);"></div>
          </div>
        </div>
      </div>
    </footer>

    <TripSidebar client:idle />

    <style>
      /* ── Desktop nav links ── */
      .nav-link:hover {
        color: #D4A843 !important;
        background: rgba(212,168,67,0.10) !important;
      }
      .logo-wrap:hover {
        box-shadow: 0 4px 16px rgba(0,0,0,0.20) !important;
        transform: translateY(-1px);
      }

      /* ── Footer links ── */
      .footer-link:hover { color: #D4A843 !important; }
      .footer-link:hover .footer-dot { background: #D4A843 !important; }

      /* ── Mobile nav items ── */
      .mobile-nav-item:hover .mobile-link-text { color: #D4A843 !important; }
      .mobile-nav-item:hover .mobile-link-arrow { stroke: rgba(212,168,67,0.90) !important; transform: translateX(4px); }
      .mobile-state-pill:hover { background: rgba(212,168,67,0.12) !important; color: #D4A843 !important; border-color: rgba(212,168,67,0.35) !important; }

      /* ── Nav scroll shadow ── */
      #main-nav { transition: box-shadow 0.3s ease; }
      #main-nav.nav-scrolled { box-shadow: 0 4px 28px rgba(20,50,10,0.35); }

      /* ── Mobile menu open state ── */
      body.menu-open { overflow: hidden; }
      #mobile-menu.is-open { opacity: 1 !important; pointer-events: all !important; }
      #mobile-menu.is-open .mobile-nav-item {
        opacity: 1 !important;
        transform: translateX(0) !important;
      }

      /* ── Hamburger → X animation ── */
      #mobile-menu-btn.is-open .ham-line:nth-child(1) {
        transform: translateY(6.5px) rotate(45deg);
      }
      #mobile-menu-btn.is-open .ham-line:nth-child(2) {
        opacity: 0;
        width: 0 !important;
      }
      #mobile-menu-btn.is-open .ham-line:nth-child(3) {
        transform: translateY(-6.5px) rotate(-45deg);
      }
    </style>

    <script>
      // ── Sticky nav shadow ──────────────────────────────────────────
      const nav = document.getElementById('main-nav');
      if (nav) {
        window.addEventListener('scroll', () => {
          nav.classList.toggle('nav-scrolled', window.scrollY > 8);
        }, { passive: true });
      }

      // ── Mobile menu ───────────────────────────────────────────────
      const menuBtn   = document.getElementById('mobile-menu-btn');
      const closeBtn  = document.getElementById('mobile-menu-close');
      const mobileMenu = document.getElementById('mobile-menu');

      function openMenu() {
        mobileMenu?.classList.add('is-open');
        menuBtn?.classList.add('is-open');
        menuBtn?.setAttribute('aria-expanded', 'true');
        mobileMenu?.setAttribute('aria-hidden', 'false');
        document.body.classList.add('menu-open');
      }
      function closeMenu() {
        mobileMenu?.classList.remove('is-open');
        menuBtn?.classList.remove('is-open');
        menuBtn?.setAttribute('aria-expanded', 'false');
        mobileMenu?.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('menu-open');
      }

      menuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.contains('is-open') ? closeMenu() : openMenu();
      });
      closeBtn?.addEventListener('click', closeMenu);

      // Close on nav link tap
      mobileMenu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', closeMenu);
      });

      // Close on Escape
      document.addEventListener('keydown', e => {
        if (e.key === 'Escape') closeMenu();
      });

      // ── Scroll-reveal observer ────────────────────────────────────
      const observer = new IntersectionObserver(
        entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
        { threshold: 0.10, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
